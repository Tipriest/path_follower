<launch>
  <arg name="path_topic" default="/run_hybrid_astar/searched_path" />
  <arg name="odom_topic" default="/gazebo_odom" />
  <arg name="cmd_vel_topic" default="/cmd_vel" />
  <arg name="debug_topic" default="/mpc_debug" />
  <arg name="enable_debug_plotter" default="true" />
  <arg name="debug_plotter_max_points" default="600" />

  <arg name="control_rate" default="10.0" />
  <arg name="dt" default="0.1" />
  <arg name="horizon_steps" default="10" />
  <arg name="lambda" default="0.1" />
  <arg name="lambda_vx" default="0.1" />
  <arg name="lambda_vy" default="5.0" />
  <arg name="allow_reverse" default="false" />
  <arg name="nearest_search_window" default="50" />
  <arg name="nonlinear_iters" default="3" />
  <arg name="ref_step" default="0.05" />
  <arg name="max_lookahead" default="2.0" />

  <arg name="max_vx" default="0.5" />
  <arg name="max_vy" default="0.3" />
  <arg name="max_w" default="1.0" />

  <node pkg="path_follower" type="mpc_path_follower_node" name="mpc_path_follower" output="screen">
    <param name="path_topic" value="$(arg path_topic)" />
    <param name="odom_topic" value="$(arg odom_topic)" />
    <param name="cmd_vel_topic" value="$(arg cmd_vel_topic)" />
    <param name="debug_topic" value="$(arg debug_topic)" />

    <param name="control_rate" value="$(arg control_rate)" />
    <param name="dt" value="$(arg dt)" />
    <param name="horizon_steps" value="$(arg horizon_steps)" />
    <param name="lambda" value="$(arg lambda)" />
    <param name="lambda_vx" value="$(arg lambda_vx)" />
    <param name="lambda_vy" value="$(arg lambda_vy)" />
    <param name="allow_reverse" value="$(arg allow_reverse)" />
    <param name="nearest_search_window" value="$(arg nearest_search_window)" />
    <param name="nonlinear_iters" value="$(arg nonlinear_iters)" />
    <param name="ref_step" value="$(arg ref_step)" />
    <param name="max_lookahead" value="$(arg max_lookahead)" />

    <param name="max_vx" value="$(arg max_vx)" />
    <param name="max_vy" value="$(arg max_vy)" />
    <param name="max_w" value="$(arg max_w)" />
  </node>

  <node pkg="map_generator" type="map_generator_node" name="map_generator_node" output="screen" />

  <node if="$(arg enable_debug_plotter)" pkg="path_follower" type="mpc_debug_plotter.py" name="mpc_debug_plotter" output="screen">
    <param name="debug_topic" value="$(arg debug_topic)" />
    <param name="max_points" value="$(arg debug_plotter_max_points)" />
  </node>


  <arg name="fixed_frame" default="world"/>

  <arg name="enable_car_model" default="true"/>
  <arg name="car_model_ns" default="car_model"/>
  <arg name="car_model_tf_prefix" default="car"/>

  <group if="$(arg enable_car_model)" ns="$(arg car_model_ns)">
    <param name="robot_description" textfile="$(find hybrid_a_star)/model/car_model/default.urdf"/>
    <node pkg="joint_state_publisher" type="joint_state_publisher" name="joint_state_publisher"/>
    <node pkg="robot_state_publisher" type="robot_state_publisher" name="robot_state_publisher">
      <param name="tf_prefix" value="$(arg car_model_tf_prefix)"/>
    </node>
  </group>

  <!-- <node pkg="rviz" type="rviz" name="rviz" args="-d $(find hybrid_a_star)/rviz/display_hybrid_astar.rviz"/> -->

  <!--static_transform_publisher x y z yaw pitch roll frame_id child_frame_id period_in_ms-->
  <!-- <node pkg="tf" type="static_transform_publisher" name="link1_broadcaster" args="0 0 0 0 0 0 world map 100"/> -->

  <!-- <node pkg="map_server" type="map_server" name="map_server" args="$(find hybrid_a_star)/maps/map.yaml"/> -->

  <node pkg="hybrid_a_star" type="run_hybrid_astar" name="run_hybrid_astar" output="screen">
    <param name="planner/steering_angle" value="15.0"/>
    <param name="planner/steering_angle_discrete_num" value="1"/>
    <param name="planner/wheel_base" value="2.0"/>
    <param name="planner/segment_length" value="1.6"/>
    <param name="planner/segment_length_discrete_num" value="8"/>
    <param name="planner/steering_penalty" value="1.5"/>
    <param name="planner/reversing_penalty" value="3.0"/>
    <param name="planner/steering_change_penalty" value="2.0"/>
    <param name="planner/shot_distance" value="5.0"/>
  </node>

</launch>
